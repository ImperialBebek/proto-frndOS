# --- Pitch real-AI gateway (OpenCode, OpenAI-compatible) ---
# Leave OPENCODE_API_KEY unset to run the prototype in mock mode (default).
# When set, the in-app "Live AI" toggle becomes available.

# Your OpenCode gateway API key (server-only, never exposed to the browser)
OPENCODE_API_KEY=

# OpenAI-compatible base URL (no trailing slash). Default shown below.
OPENCODE_BASE_URL=https://opencode.ai/zen/v1

# Text model used for brief decode + field regeneration (see /zen/v1/models)
OPENCODE_MODEL=minimax-m2.7

# Optional vision-capable model for decoding image-only PDF uploads.
# Leave unset to fall back to the paste-text path for image PDFs.
OPENCODE_VISION_MODEL=
